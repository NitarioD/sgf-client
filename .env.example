# Backend API base (browser). Set at least one; if both are set, NEXT_PUBLIC_API_URL wins.
# Example: https://api.example.com/api
# Must run `npm run build` after changing these — values are baked into the client bundle.
NEXT_PUBLIC_API_URL=

# Alternate name for the same base URL (fallback if NEXT_PUBLIC_API_URL is unset)
NEXT_PUBLIC_API=

# Paystack inline/public key for WebPay (admin)
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=
